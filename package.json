    "desktop": "unset ELECTRON_RUN_AS_NODE && TMPDIR=/tmp electron electron/main.js"
  },
  "dependencies": {
    "gulp": "^4.0.2",
    "gulp-concat": "^2.6.1",
    "gulp-connect": "^5.7.0",
    "json5": "^2.1.3",
    "rollup": "^1.31.1",
    "through": "~2.3.4"
  },
  "devDependencies": {
    "electron": "21.3.1"
  },
  "author": "Markus Schütz",
  "license": "BSD-2-CLAUSE"
}
