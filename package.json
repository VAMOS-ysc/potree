{
  "name": "potree",
  "private": true,
  "version": "1.8.0",
  "description": "WebGL point cloud viewer",
  "keywords": [
    "point",
    "cloud",
    "pointcloud",
    "octree",
    "entwine",
    "viewer",
    "threejs",
    "webgl",
    "browser",
    "tool"
  ],
  "main": "./build/potree/potree.js",
  "scripts": {
    "start": "gulp watch",
    "build": "gulp build pack",
